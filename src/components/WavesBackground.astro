---
interface Props {
  mode?: 'animated' | 'static';
}
const { mode = 'animated' } = Astro.props;
---

<canvas id="waves-bg" data-mode={mode} aria-hidden="true"></canvas>

<style>
  #waves-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: -10;
    display: block;
    pointer-events: none;
    background: var(--background);
  }
</style>

<script>
  import { initWaves } from '../scripts/waves';

  const canvas = document.getElementById('waves-bg') as HTMLCanvasElement | null;
  if (canvas) {
    const mode = (canvas.dataset.mode as 'animated' | 'static') ?? 'animated';
    const run = () => initWaves(canvas, mode);
    if ('requestIdleCallback' in window) {
      (window as any).requestIdleCallback(run, { timeout: 500 });
    } else {
      setTimeout(run, 1);
    }
  }
</script>
