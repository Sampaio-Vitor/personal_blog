---
const links = [
  { label: 'GitHub',   href: 'https://github.com/' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/' },
  { label: 'Email',    href: 'mailto:hello@vitorsampa.io' },
  { label: 'RSS',      href: '/rss.xml' },
];
---
<section class="p-4 md:p-5">
  <p class="font-mono text-[0.65rem] uppercase tracking-wider text-foreground-muted mb-2">
    // contact
  </p>
  <ul class="space-y-1.5">
    {links.map((l) => (
      <li>
        <a
          href={l.href}
          class="font-mono text-xs text-foreground hover:text-accent underline-offset-4 hover:underline"
        >
          {l.label}
        </a>
      </li>
    ))}
  </ul>
</section>
