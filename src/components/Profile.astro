---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';
---

<section class="p-4 md:p-5 border-b-2 border-foreground">
  <button
    id="logo-trigger"
    type="button"
    aria-label="Open logo full size"
    class="w-28 h-28 md:w-32 md:h-32 border-2 border-foreground shadow-brutal mb-4 cursor-zoom-in focus-ring block"
  >
    <Image
      src={logo}
      alt="Vitor Sampaio"
      width={384}
      height={384}
      quality={95}
      class="w-full h-full object-cover"
    />
  </button>
  <p class="font-mono text-[0.65rem] uppercase tracking-wider text-foreground-muted mb-1.5">
    ~/vitorsampa.io
  </p>
  <h1 class="font-display font-extrabold text-2xl md:text-3xl leading-none tracking-tight mb-3 pb-2 border-b-4 border-foreground break-all">
    vitor_sampaio
  </h1>
  <p class="font-mono text-[0.65rem] uppercase tracking-[0.2em] text-accent mb-4">
    ML ENG · SWE
  </p>
  <p class="font-sans text-sm leading-relaxed text-foreground">
    Notes on shipping ML systems, the software around them, and whatever
    else I'm thinking about. Mostly Python, occasionally otherwise.
  </p>
</section>

<!-- Lightbox overlay -->
<div
  id="logo-lightbox"
  role="dialog"
  aria-modal="true"
  aria-label="Enlarged logo"
  class="fixed inset-0 z-50 flex items-center justify-center bg-[rgba(0,0,0,0.75)] opacity-0 pointer-events-none transition-opacity duration-200"
>
  <div class="relative max-w-lg w-full mx-4">
    <button
      id="logo-lightbox-close"
      type="button"
      aria-label="Close"
      class="absolute -top-3 -right-3 bg-foreground text-background w-8 h-8 border-2 border-foreground shadow-brutal-sm font-mono text-sm font-bold flex items-center justify-center hover:bg-accent hover:text-background transition-colors focus-ring z-10"
    >✕</button>
    <div class="border-2 border-foreground bg-surface shadow-brutal-lg overflow-hidden">
      <Image
        src={logo}
        alt="Me and my dog - Monese - on an 80's anime style. I love this aesthetic"
        width={768}
        height={768}
        quality={95}
        class="w-full aspect-square object-cover block"
      />
      <p class="font-serif italic text-lg md:text-xl text-foreground text-center py-3 px-4 border-t-2 border-foreground bg-surface">
        Me and my dog — Monese — on an 80's anime style. I love this aesthetic
      </p>
    </div>
  </div>
</div>

<script>
  const trigger = document.getElementById('logo-trigger');
  const lightbox = document.getElementById('logo-lightbox');
  const closeBtn = document.getElementById('logo-lightbox-close');

  function openLightbox() {
    lightbox!.classList.remove('opacity-0', 'pointer-events-none');
    lightbox!.classList.add('opacity-100', 'pointer-events-auto');
    document.body.style.overflow = 'hidden';
    closeBtn?.focus();
  }

  function closeLightbox() {
    lightbox!.classList.remove('opacity-100', 'pointer-events-auto');
    lightbox!.classList.add('opacity-0', 'pointer-events-none');
    document.body.style.overflow = '';
    trigger?.focus();
  }

  trigger?.addEventListener('click', openLightbox);
  closeBtn?.addEventListener('click', closeLightbox);
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && lightbox?.classList.contains('opacity-100')) closeLightbox();
  });
</script>
