---
import '../styles/global.scss';
import WavesBackground from '../components/WavesBackground.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  wavesMode?: 'animated' | 'static';
}

const {
  title = 'vitorsampa.io',
  description = 'Vitor Sampaio — machine learning engineer & software engineer. Notes, projects, and writing.',
  canonical,
  ogImage = '/og-default.png',
  wavesMode = 'animated',
} = Astro.props;

const siteUrl = 'https://vitorsampa.io';
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).toString();
const fullTitle = title === 'vitorsampa.io' ? title : `${title} — vitorsampa.io`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="vitorsampa.io" href="/rss.xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="vitorsampa.io" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={new URL(ogImage, siteUrl).toString()} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, siteUrl).toString()} />

    <meta name="DC.title" content={fullTitle} />
    <meta name="DC.creator" content="Vitor Sampaio" />

    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: 'Vitor Sampaio',
      url: siteUrl,
      jobTitle: 'Machine Learning Engineer & Software Engineer',
    })} />

  </head>
  <body class="text-foreground font-mono min-h-screen">
    <WavesBackground mode={wavesMode} />
    <slot />

    <button
      id="peek-waves-btn"
      type="button"
      class="fixed bottom-4 left-1/2 -translate-x-1/2 z-20 font-mono text-[11px] tracking-wide text-center max-w-[calc(100vw-2rem)] px-3 py-1.5 border-2 border-foreground bg-surface text-foreground shadow-brutal-sm hover:bg-accent hover:text-foreground-inverse"
    >
      Nice background huh? Click here to fetch.
    </button>

    <style is:global>
      main { transition: opacity 0.6s ease; }
      #peek-waves-btn { transition: background-color 0.15s ease, color 0.15s ease; }
      body.peek-waves main { opacity: 0; pointer-events: none; }
    </style>

    <script>
      const btn = document.getElementById('peek-waves-btn');
      const DURATION = 20;
      let interval: ReturnType<typeof setInterval> | undefined;
      let idleText = '';

      function restore() {
        document.body.classList.remove('peek-waves');
        if (interval) { clearInterval(interval); interval = undefined; }
        window.removeEventListener('click', restore);
        if (btn) btn.textContent = idleText;
      }

      function reveal() {
        if (!btn) return;
        idleText = btn.textContent ?? '';
        document.body.classList.add('peek-waves');

        let left = DURATION;
        btn.textContent = `back in ${left}s — click to return`;
        interval = setInterval(() => {
          left -= 1;
          if (left <= 0) { restore(); return; }
          btn.textContent = `back in ${left}s — click to return`;
        }, 1000);

        // defer so the click that triggered reveal doesn't immediately restore
        setTimeout(() => window.addEventListener('click', restore, { once: true }), 0);
      }

      btn?.addEventListener('click', () => {
        if (document.body.classList.contains('peek-waves')) restore();
        else reveal();
      });
    </script>
  </body>
</html>
